{
  "name": "ting-ear",
  "version": "1.0.0",
  "description": "听伴 - Windows 桌面 TTS 朗读伴侣",
  "main": "./out/main/index.js",
  "author": "TingEar",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint electron/ src/",
    "format": "prettier --write \"electron/**/*.ts\" \"src/**/*.{ts,tsx,css}\"",
    "test": "tsx tests/textPreprocessor.test.ts && tsx tests/bookData.test.ts && tsx tests/parserCompatibility.test.ts && tsx tests/engineImport.test.ts && tsx tests/albumUtils.test.ts",
    "postinstall": "electron-builder install-app-deps",
    "package": "electron-vite build && electron-builder --win",
    "package:dir": "electron-vite build && electron-builder --win --dir"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/adm-zip": "^0.5.8",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "adm-zip": "^0.5.18",
    "axios": "^1.7.0",
    "iconv-lite": "^0.6.3",
    "jschardet": "^3.0.0",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.12.0",
    "msedge-tts": "^2.0.6",
    "pdf-parse": "^1.1.1",
    "pdf2json": "^4.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.0.0",
    "ws": "^8.21.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^28.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.4.49",
    "prettier": "^3.9.4",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.0"
  }
}
